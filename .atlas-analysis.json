  "keyFeatures": [
    "macOS sandbox-exec wrapper with deny-first security model",
    "Composable policy profiles for fine-grained access control",
    "Support for 14+ coding agents (Claude, Cursor, Aider, Goose, etc.)",
    "Modular integration system (Docker, kubectl, SSH, clipboard, 1Password, etc.)",
    "CLI-driven path grants and feature toggles",
    "Machine-specific local overrides and appended profiles",
    "Workdir-based .safehouse config files for project-specific policies",
    "Deterministic policy generation and distribution artifacts"
  ],
  "publicApiSurface": [
    "safehouse - Generate sandbox policy for current directory",
    "safehouse --stdout - Print policy text to stdout",
    "safehouse -- <command> - Execute command inside sandbox",
    "safehouse --enable=<features> - Enable optional integrations (docker, kubectl, macos-gui, electron, ssh, clipboard, 1password, etc.)",
    "safehouse --add-dirs-ro=<paths> - Add read-only directory access",
    "safehouse --add-dirs=<paths> - Add read-write directory access",
    "safehouse --append-profile=<file> - Append custom policy file",
    "safehouse --trust-workdir-config - Trust .safehouse config in working directory",
    "safehouse --workdir=<path> - Override working directory for policy generation",
    "safehouse --explain - Show detailed policy selection and grants",
    "safehouse --env - Pass full environment to sandboxed command",
    "safehouse --env-pass=<vars> - Pass specific environment variables"
  ]
}
